---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Delete Data - Bahar"
  description="Delete your data or request account deletion for Bahar."
  hideLanguageSwitcher={true}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex">
  </Fragment>

  <div class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-4xl font-bold tracking-tight">Delete Data</h1>

    <div class="mt-8 space-y-8 text-foreground">
      <section id="delete-user-data">
        <h2 class="text-2xl font-semibold">Delete user data</h2>
        <p class="mt-3 text-muted-foreground">
          You can permanently delete all of your dictionary entries, flashcards,
          and decks without deleting your account. This is immediate and cannot
          be undone.
        </p>
        <ul class="mt-3 list-disc space-y-2 ps-6 text-muted-foreground">
          <li>
            <strong>Mobile app:</strong>Go to <strong>Settings</strong>&gt;
            <strong>Danger Zone</strong>&gt; <strong>Delete All Data</strong>
          </li>
          <li>
            <strong>Web app:</strong>Go to <strong>Settings</strong>&gt;
            <strong>Dictionary</strong>&gt; <strong>Delete</strong>
          </li>
        </ul>
      </section>

      <section id="delete-account">
        <h2 class="text-2xl font-semibold">Delete your account</h2>
        <p class="mt-3 text-muted-foreground">
          When you request account deletion, we will permanently delete:
        </p>
        <ul class="mt-3 list-disc space-y-2 ps-6 text-muted-foreground">
          <li>Your account and authentication credentials</li>
          <li>Your personal dictionary entries</li>
          <li>All flashcards and spaced repetition progress</li>
          <li>Your study decks</li>
          <li>Any subscription or billing information</li>
        </ul>
        <p class="mt-3 text-muted-foreground">
          This action is permanent and cannot be undone.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold">How to request deletion</h2>
        <p class="mt-3 text-muted-foreground">
          Send an email to
          <a
            href="mailto:support@bahar.dev?subject=Account%20Deletion%20Request"
            class="font-medium text-primary hover:underline"
            >support@bahar.dev</a
          >
          with the subject line "Account Deletion Request" and include the email
          address associated with your account. We will process your request
          within 7 days and send you a confirmation once your data has been
          deleted.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold">Questions?</h2>
        <p class="mt-3 text-muted-foreground">
          If you have any questions about this process, contact us at
          <a
            href="mailto:support@bahar.dev"
            class="font-medium text-primary hover:underline"
            >support@bahar.dev</a
          >.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>
