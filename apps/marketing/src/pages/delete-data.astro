---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Delete Data - Bahar"
  description="Delete your data or request account deletion for Bahar."
  hideLanguageSwitcher={true}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex">
  </Fragment>

  <div class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="text-4xl font-bold tracking-tight">Delete Data</h1>

    <div class="mt-8 space-y-8 text-foreground">
      <section id="delete-dictionary">
        <h2 class="text-2xl font-semibold">Delete dictionary data</h2>
        <p class="mt-3 text-muted-foreground">
          You can permanently delete all of your dictionary entries, flashcards,
          and decks without deleting your account. This is immediate and cannot
          be undone.
        </p>
        <ul class="mt-3 list-disc space-y-2 ps-6 text-muted-foreground">
          <li>
            <strong>Mobile app:</strong>Go to <strong>Settings</strong>&gt;
            <strong>Danger Zone</strong>&gt; <strong>Delete All Data</strong>
          </li>
          <li>
            <strong>Web app:</strong>Go to <strong>Settings</strong>&gt;
            <strong>Dictionary</strong>&gt; <strong>Delete</strong>
          </li>
        </ul>
      </section>

      <section id="delete-account">
        <h2 class="text-2xl font-semibold">Delete your account</h2>
        <p class="mt-3 text-muted-foreground">
          You can permanently delete your Bahar account from within the app.
          Deleting your account will remove:
        </p>
        <ul class="mt-3 list-disc space-y-2 ps-6 text-muted-foreground">
          <li>Your account and sign-in credentials</li>
          <li>Your personal dictionary entries, flashcards, and decks</li>
          <li>All flashcard review history and progress</li>
          <li>Any active subscription</li>
          <li>Your marketing email preferences</li>
        </ul>

        <p class="mt-6 text-muted-foreground">To delete your account:</p>
        <ul class="mt-3 list-disc space-y-2 ps-6 text-muted-foreground">
          <li>
            <strong>Mobile app:</strong>Go to <strong>Settings</strong>&gt;
            <strong>Danger Zone</strong>&gt; <strong>Delete Account</strong>
          </li>
          <li>
            <strong>Web app:</strong>Go to <strong>Settings</strong>&gt;
            <strong>Account</strong>&gt; <strong>Delete account</strong>
          </li>
        </ul>

        <p class="mt-6 text-muted-foreground">
          For your security, you must have signed in within the past 24 hours.
          If your session is older, you'll be asked to sign in again before the
          account can be deleted.
        </p>
        <p class="mt-3 text-muted-foreground">
          This action is permanent and cannot be undone.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-semibold">Need help?</h2>
        <p class="mt-3 text-muted-foreground">
          If you can't access your account or need help, email us at
          <a
            href="mailto:support@bahar.dev?subject=Account%20Deletion%20Request"
            class="font-medium text-primary hover:underline"
            >support@bahar.dev</a
          >
          and we'll process your request within 7 days.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>
